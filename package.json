{
  "name": "auto-refresher",
  "version": "1.0.0",
  "description": "Chrome/Edge extension that auto-refreshes the active tab at a configurable interval",
  "private": true,
  "scripts": {
    "build": "npm run clean && tsc && node scripts/copy-assets.js",
    "watch": "tsc --watch",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^25.5.0",
    "chrome-types": "^0.1.327",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  }
}
